# =============================================================
# Departmental Store Billing - Environment Variables Example
# Copy this file to .env and fill in your actual values
# Never commit .env to version control
# =============================================================

# -------------------------
# Database Configuration
# -------------------------
# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# -------------------------
# Authentication
# -------------------------
# Secret key for JWT token signing (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Token expiration
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------
# Application Settings
# -------------------------
NODE_ENV=production
API_PORT=3001

# -------------------------
# Frontend Configuration
# -------------------------
# URL of Netlify Functions API
REACT_APP_API_URL=/.netlify/functions
REACT_APP_APP_NAME=Departmental Store Billing
REACT_APP_VERSION=1.0.0
REACT_APP_ENV=production

# -------------------------
# Payment Gateway (Razorpay)
# -------------------------
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-key

# Public key for frontend
REACT_APP_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# -------------------------
# Email Configuration (Gmail)
# -------------------------
EMAIL_SERVICE=gmail
EMAIL_USER=billing@yourstore.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM_NAME=Departmental Store

# -------------------------
# SMS Configuration (Twilio)
# -------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

# -------------------------
# Supabase Configuration
# -------------------------
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Frontend Supabase keys
REACT_APP_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key

# -------------------------
# Store Configuration
# -------------------------
STORE_NAME=My Departmental Store
STORE_ADDRESS=123 Store Street, City, State - 000000
STORE_PHONE=+91 XXXXX XXXXX
STORE_EMAIL=info@yourstore.com
STORE_GST_NUMBER=XXXXXXXXXXXX
STORE_PAN_NUMBER=XXXXXXXXXX

# -------------------------
# Monitoring (Optional)
# -------------------------
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
REACT_APP_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# -------------------------
# Rate Limiting
# -------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
